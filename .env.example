# paper | live — server-side only (never NEXT_PUBLIC_)
TRADING=paper

# Starting cash for paper book (used when TRADING=paper)
PAPER_CAPITAL=100000

# Max % of capital to risk per new trade (capped in code at 5)
MAX_RISK_PER_TRADE_PCT=1

# Groww Trade API — only on server, rotate regularly
# https://groww.in/trade-api/docs/curl
GROWW_ACCESS_TOKEN=

# Max drawdown vs day-start equity (IST) before paper auto-entries stop
MAX_DAILY_LOSS_PCT=3

# Max concurrent paper positions
MAX_OPEN_POSITIONS=3

# Set to 1 to block new paper auto-entries and live /api/order
KILL_SWITCH=0

# Live order route: 1 = validate only (no broker call). Set 0 after checks.
ORDER_DRY_RUN=1

# Required header X-Order-Secret on POST /api/order (min 8 chars)
ORDER_API_SECRET=
